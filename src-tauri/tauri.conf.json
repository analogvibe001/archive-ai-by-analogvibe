{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Archive AI",
  "version": "2.0.0",
  "identifier": "com.archiveai.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Archive AI",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/128x128.png", "icons/icon.png", "icons/icon.icns"],
    "resources": ["templates/*", "data/*"],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
