    "keywords": ["produccion", "producción", "prod", "shooting", "shoot", "rodaje", "grabacion", "grabación", "sesion", "sesión", "fotos", "videos", "reel", "contenido", "content"],
    "filePatterns": ["*.arw", "*.cr2", "*.dng", "*.raw", "*.nef", "*.jpg", "*.mp4", "*.mov", "*.braw"],
