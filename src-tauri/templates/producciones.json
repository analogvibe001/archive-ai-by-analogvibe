    "level3_photo": "Fotos - {day} - {month_name} - {type} - {year} - {brand}",
    "level3_video": "Videos - {day} - {month_name} - {type} - {year} - {brand}",
    "level4_photo_raw": "Fotos RAW - Fotos - {day} - {month_name} - {type} - {year} - {brand}",
    "level4_photo_edit": "Fotos Editadas - Fotos - {day} - {month_name} - {type} - {year} - {brand}",
    "level4_video_raw": "Videos RAW - Videos - {day} - {month_name} - {type} - {year} - {brand}",
    "level4_video_edit": "Videos Editados - Videos - {day} - {month_name} - {type} - {year} - {brand}"
